FROM ghcr.io/project-osrm/osrm-backend:v6.0.0@sha256:b94bc7f32bae6d96bea9344ae51f612ca67c7d776d6c6f96a15b6134d244e4c0

#FROM ghcr.io/project-osrm/osrm-backend:v5.27.1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    build-essential \
    git \
    cmake \
    pkg-config \
    python3-dev \
    wget \ 
    curl \
    gnupg2 \
    libboost-all-dev

ARG osm_download_url

ARG osm_filename_arg

ENV osm_filename $osm_filename_arg

RUN wget -O "$osm_filename_arg.osm.pbf" --no-check-certificate $osm_download_url

RUN wget https://repo.anaconda.com/miniconda/Miniconda3-py313_26.1.1-1-Linux-x86_64.sh

RUN bash Miniconda3-py313_26.1.1-1-Linux-x86_64.sh -b -p /opt/conda

ENV PATH="${PATH}:/opt/conda/bin"

RUN mkdir /opt/defaultprofiles

RUN mv /opt/*.lua /opt/defaultprofiles/

COPY /veh_profiles/* /opt/

COPY build_parameters.yml .

COPY build_vehicle_profiles.py .

RUN /opt/conda/bin/python build_vehicle_profiles.py

COPY requirements.txt .

RUN /opt/conda/bin/python -m pip install -r requirements.txt

RUN apt-get -y install vim

RUN git clone --depth=1 -b v3.0.0 https://github.com/pybind/pybind11.git

RUN mkdir -p /opt/bindings
COPY c_binding_resources/CMakeLists.txt /opt/bindings/

COPY c_binding_resources/python_bindings.cpp /opt/bindings/example.cpp

RUN cp -r /usr/local/include /opt/bindings/include

RUN cp -r /opt/pybind11 /opt/bindings/pybind11

RUN git clone --depth=1 \
    https://github.com/Project-OSRM/osrm-backend.git /opt/osrm-src \
 && cp -r /opt/osrm-src/include/* /opt/bindings/include/ \
 && cp -r /opt/osrm-src/third_party/fmt/include/fmt /opt/bindings/include/fmt \
 && rm -rf /opt/osrm-src

RUN apt-get remove -y libfmt-dev || true

# build fmt from the same source OSRM used
RUN git clone --depth=1 -b 10.2.1 https://github.com/fmtlib/fmt.git /opt/fmt-src \
 && cmake -S /opt/fmt-src -B /opt/fmt-src/build \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
      -DFMT_TEST=OFF \
 && cmake --build /opt/fmt-src/build --parallel $(nproc) \
 && cmake --install /opt/fmt-src/build --prefix /opt/fmt \
 && rm -rf /opt/fmt-src

RUN cd /opt/bindings && mkdir build && cd build && \
    cmake .. \
      -DPython_EXECUTABLE=/opt/conda/bin/python \
      -Dfmt_DIR=/opt/fmt/lib/cmake/fmt \
    && make

RUN mkdir data

RUN mkdir data/gps_data_clean

RUN mkdir data/time_and_dist_matrices

COPY ["/local_data/customer_data.xlsx", "data/."]

COPY /local_data/extra_points.csv data/.

COPY /local_data/config.json data/.

COPY /local_data/custom_header.yaml data/.

RUN mkdir maps

RUN mkdir manual_edits

RUN mkdir manual_edits/maps

COPY manual.ipynb .

COPY manual.sh .

COPY Makefile .

RUN mkdir -p py-lib

RUN mv /opt/bindings/build/osrmbindings.cpython-313-x86_64-linux-gnu.so py-lib/

RUN apt-get install -y libfmt-dev

COPY src src

ENV PYTHONPATH "${PYTHONPATH}:./py-lib:/src/python"

ENV LD_LIBRARY_PATH=/usr/local/lib:/usr/lib/x86_64-linux-gnu

CMD ["/opt/conda/bin/python", "/src/py/main_application.py", "--local"]

